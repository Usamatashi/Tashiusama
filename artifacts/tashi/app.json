{
  "expo": {
    "name": "Tashi",
    "slug": "tashi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tashi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E87722"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tashi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Tashi uses your camera to scan QR codes and earn points.",
        "NSContactsUsageDescription": "Tashi uses your contacts to quickly fill in phone numbers when creating accounts."
      }
    },
    "android": {
      "package": "com.tashi.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E87722"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E87722",
          "androidMode": "default",
          "androidCollapsedTitle": "Tashi"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Tashi to save QR codes to your photo library.",
          "savePhotosPermission": "Allow Tashi to save QR codes to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tashi uses your camera to scan QR codes and earn points."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "736121db-06bb-43dd-b95c-c29bbbdbcb92"
      }
    }
  }
}
