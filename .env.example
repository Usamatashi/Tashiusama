# ============================================================
# Tashi API Server — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Required ---

# PostgreSQL connection string
# Railway: copy from your Railway PostgreSQL service → Connect tab
# Neon: copy from your Neon dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Server port (Railway sets this automatically)
PORT=8080

# --- Security (Required in production) ---

# JWT signing secret — use a long random string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-string

# --- Super Admin Credentials ---
# Credentials for the default super admin account created on first boot
# Change these before deploying to production!
SUPER_ADMIN_PHONE=03055198651
SUPER_ADMIN_PASSWORD=khan0112

# --- CORS (Optional) ---
# Comma-separated list of allowed origins for the API
# Leave as * to allow all origins (not recommended for production)
# CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# --- Logging ---
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# --- Node Environment ---
NODE_ENV=production
